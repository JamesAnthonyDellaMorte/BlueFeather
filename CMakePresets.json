{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "environment": {
        "CLICOLOR_FORCE": "1",
        "FORCE_COLOR": "1"
      },
      "cacheVariables": {
        "CMAKE_COLOR_DIAGNOSTICS": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/CMake/HideSystemSpdlog.cmake",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdeb",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-relwithdeb",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-base",
      "hidden": true,
      "environment": {
        "CLICOLOR_FORCE": "1",
        "FORCE_COLOR": "1"
      }
    },
    {
      "name": "release",
      "inherits": "build-base",
      "configurePreset": "release",
      "targets": [
        "BlueFeather"
      ]
    },
    {
      "name": "relwithdeb",
      "inherits": "build-base",
      "configurePreset": "relwithdeb",
      "targets": [
        "BlueFeather"
      ]
    },
    {
      "name": "debug",
      "inherits": "build-base",
      "configurePreset": "debug",
      "targets": [
        "BlueFeather"
      ]
    }
  ]
}
